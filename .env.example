VENICE_API_KEY=vapi_your_key_here
VENICE_TEXT_MODEL=zai-org-glm-5
VENICE_IMAGE_MODEL=grok-imagine-image
INVICTUS_ACCESS_CODE=change-this-private-code
INVICTUS_SYSTEM_PROMPT=Eres el companero privado del Agora de Acuario. Responde en espanol con calidez, claridad, memoria conversacional dentro del chat actual y tono creativo.
AGORA_DEFAULT_MEMBER=ApolloSol

# Firebase Admin para rutas servidor en Vercel.
# Opcion A: pega el JSON completo del service account en una sola variable.
FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"your-project","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Opcion B: usa campos separados en vez de FIREBASE_SERVICE_ACCOUNT_JSON.
# FIREBASE_PROJECT_ID=your-project
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n
